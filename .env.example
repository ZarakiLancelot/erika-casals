# =================================
# VARIABLES DE ENTORNO - FULLSTACK VERCEL
# =================================

# FRONTEND VARIABLES (con prefijo VITE_)
# Backend API URL - Para desarrollo local usa http://localhost:5000
# Para producción en Vercel será la misma URL del frontend
VITE_API_URL=https://tu-dominio.com

# Contentful CMS (para acceso directo del frontend)
VITE_CONTENTFUL_SPACE_ID=your_contentful_space_id
VITE_CONTENTFUL_ACCESS_TOKEN=your_contentful_access_token

# =================================
# BACKEND VARIABLES (sin prefijo VITE_)
# Estas variables solo se usan en las funciones serverless
# NUNCA se exponen al cliente
# =================================

# Credenciales de Idealista Partners API (método antiguo - opcional)
IDEALISTA_CLIENT_ID=tu_client_id_aqui
IDEALISTA_CLIENT_SECRET=tu_client_secret_aqui
IDEALISTA_FEED_KEY=tu_feed_key_aqui

# Credenciales de Idealista FTP Feed (método nuevo - recomendado)
IDEALISTA_FTP_HOST=ftp.habitania.com
IDEALISTA_FTP_USER=tu_usuario_ftp
IDEALISTA_FTP_PASSWORD=tu_password_ftp

# Entorno (production o development)
NODE_ENV=production

# =================================
# CONFIGURACIÓN EN VERCEL:
# =================================
# 1. Ve a tu proyecto en vercel.com
# 2. Ve a Settings > Environment Variables
# 3. Agrega cada variable con su valor correspondiente
# 4. Las variables VITE_ están disponibles en el frontend
# 5. Las variables sin VITE_ solo están en el backend serverless
