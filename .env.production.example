# VARIABLES DE ENTORNO PARA PRODUCCIÓN
# Copia este archivo como .env.production y completa con tus datos reales

# =============================================
# FRONTEND - Variables que empiezan con VITE_
# =============================================

# URL del backend en producción (Railway, Render, etc.)
VITE_BACKEND_URL=https://tu-backend-en-railway.railway.app

# Contentful CMS
VITE_CONTENTFUL_SPACE_ID=tu_space_id_de_contentful
VITE_CONTENTFUL_ACCESS_TOKEN=tu_access_token_de_contentful

# =============================================
# BACKEND - Variables del servidor Node.js
# =============================================

# Puerto del servidor (Railway lo asigna automáticamente)
PORT=3000

# Entorno de ejecución
NODE_ENV=production

# Idealista API Credentials
IDEALISTA_CLIENT_ID=tu_client_id_de_idealista
IDEALISTA_CLIENT_SECRET=tu_client_secret_de_idealista
IDEALISTA_FEED_KEY=tu_feed_key_de_idealista

# Contentful (para el backend también)
CONTENTFUL_SPACE_ID=tu_space_id_de_contentful
CONTENTFUL_ACCESS_TOKEN=tu_access_token_de_contentful

# CORS Origins (dominios permitidos)
CORS_ORIGINS=https://tu-dominio.com,https://www.tu-dominio.com
